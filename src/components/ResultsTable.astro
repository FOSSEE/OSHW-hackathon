---
type PrimitiveCell = string | number;

interface TableCell {
  content?: PrimitiveCell;
  value?: PrimitiveCell;
  rowspan?: number;
  colspan?: number;
  html?: boolean;
  class?: string;
}

type Cell = PrimitiveCell | TableCell;
type Row = Cell[];

interface Props {
  headers: Cell[] | Row[];
  rows: Row[];
  htmlCells?: boolean; // allow <br> etc. inside cells
}

const { headers = [], rows = [], htmlCells = true } = Astro.props as Props;

const normalizedHeaders = Array.isArray(headers[0])
  ? (headers as Row[])
  : [headers as Cell[]];

const normalizeCell = (cell: Cell): Required<Pick<TableCell, "rowspan" | "colspan">> & TableCell => {
  if (typeof cell === "object" && cell !== null && !Array.isArray(cell)) {
    return {
      rowspan: 1,
      colspan: 1,
      ...cell,
    };
  }

  return {
    content: cell,
    rowspan: 1,
    colspan: 1,
  };
};

const getCellContent = (cell: TableCell) => cell.content ?? cell.value ?? "";
---
<table class="w-full table-auto border border-gray-200 rounded-xl overflow-hidden text-lg">
<thead class="bg-gray-50">
{normalizedHeaders.map((headerRow: Row) => (
<tr>
{headerRow.map((headerCell: Cell) => {
const cellData = normalizeCell(headerCell);
const content = getCellContent(cellData);
const shouldRenderHtml =
  (cellData.html ?? htmlCells) && typeof content === "string" && content.includes("<");

return shouldRenderHtml
  ? (
    // eslint-disable-next-line @typescript-eslint/ban-ts-comment
    // @ts-ignore - Astro directive, safe when you trust input
    <th
      class={`text-left font-semibold px-3 py-2 border-b border-gray-200${cellData.class ? ` ${cellData.class}` : ""}`}
      colspan={cellData.colspan > 1 ? cellData.colspan : undefined}
      rowspan={cellData.rowspan > 1 ? cellData.rowspan : undefined}
      scope="col"
      set:html={content}
    />
  )
  : (
    <th
      class={`text-left font-semibold px-3 py-2 border-b border-gray-200${cellData.class ? ` ${cellData.class}` : ""}`}
      colspan={cellData.colspan > 1 ? cellData.colspan : undefined}
      rowspan={cellData.rowspan > 1 ? cellData.rowspan : undefined}
      scope="col"
    >
      {content}
    </th>
  );
})}
</tr>
))}
</thead>
<tbody>
{rows.map((r: Row) => (
<tr class="even:bg-gray-50/40 hover:bg-gray-100/60">
{r.map((cell: Cell) => {
const cellData = normalizeCell(cell);
const content = getCellContent(cellData);
const shouldRenderHtml =
  (cellData.html ?? htmlCells) && typeof content === "string" && content.includes("<");

return shouldRenderHtml
  ? (
    // eslint-disable-next-line @typescript-eslint/ban-ts-comment
    // @ts-ignore - Astro directive, safe when you trust input
    <td
      class={`text-lg px-3 py-2 align-top border-t border-gray-200${cellData.class ? ` ${cellData.class}` : ""}`}
      colspan={cellData.colspan > 1 ? cellData.colspan : undefined}
      rowspan={cellData.rowspan > 1 ? cellData.rowspan : undefined}
      set:html={content}
    />
  )
  : (
    <td
      class={`text-lg px-3 py-2 align-top border-t border-gray-200${cellData.class ? ` ${cellData.class}` : ""}`}
      colspan={cellData.colspan > 1 ? cellData.colspan : undefined}
      rowspan={cellData.rowspan > 1 ? cellData.rowspan : undefined}
    >
      {content}
    </td>
  );
})}
</tr>
))}
</tbody>
</table>
<style>
table {
  box-shadow: none;
  background-color: white;
  transition: 0.3s;
}

table:hover {
  box-shadow: 0px 5px 58px 0px rgba(36, 80, 80, 0.7);
  /* scale: 1.1; */
}

a {
  color: #4e6e8a;
  text-decoration: none;
  text-transform: uppercase;
  padding-bottom: 3px;
  margin-bottom: 3px;
}

a:hover {
  background-color: #4e6e8a;
  text-decoration: underline;
  color: white;
}

a:active {
  background-color: #4e6e8a;
}

tr, th, td {
  border: 2px solid #4e6e8a;
  padding: 5px;
}

.tabs {
  display: flex;
  cursor: pointer;
}

.tab {
  padding: 10px 20px;
  border: 1px solid #ccc;
  border-bottom: none;
  background: #f1f1f1;
}

.tab:hover {
  background: #4e6e8a;
  color: white;
}

.tab.active {
  background: #4e6e8a;
  color: white;
  font-weight: bold;
}

.tab-content {
  border: 1px solid #ccc;
  padding: 20px;
  background: #fff;
}

.tab-content > div {
  display: none;
}

.tab-content > div.active {
  display: block;
}
</style>
