---
import Layout from "../layouts/Layout.astro";
import DataTable from "../components/ResultsTable.astro";
import SectionTitle from "../components/SectionTitle.astro";
import {
  headers,
  champions,
  winners,
  notable,
  participation,
} from "../data/resulttable.js";
---
<Layout title="Results | FOSSEE OSHW Hackathon 2026">
  <SectionTitle id="abouttitle" title="Results" />
   

<div class="tabs">
  <div class="tab active" data-tab="0">Champion</div>
  <div class="tab" data-tab="1">Winners</div>
  <div class="tab" data-tab="2">Notable Contributions</div>
  <div class="tab" data-tab="3">Participation</div>
</div>

<div class="tab-content">
  <div class="tab-panel active" id="tab-0">
    <div class="overflow-x mt-5 pt-5 pb-5 mb-5">
 
<DataTable headers={headers} rows={champions} />
</div>
</div>

 <!---------------Tab-2------------------->
    <div class="tab-panel" id="tab-1">
       <div class="overflow-x mt-5 pt-5 pb-5 mb-5">


<DataTable headers={headers} rows={winners} />
</div>
</div>

 <div class="tab-panel" id="tab-2">
    <div class="overflow-x mt-5 pt-5 pb-5 mb-5">


<DataTable headers={headers} rows={notable} />
</div>
</div>

 <div class="tab-panel" id="tab-3">
    <div class="overflow-x mt-5 pt-5 pb-5 mb-5">


<DataTable headers={headers} rows={participation} />
</div>
</div>
</div>
</Layout>
<style>
table {
  box-shadow: none;
  background-color: white;
  transition: 0.3s;
}

/* Match the new theme color in the hover shadow (optional but nicer) */
table:hover {
  box-shadow: 0px 5px 58px 0px rgba(78, 110, 138, 0.35);
  /* scale: 1.1; */
}

a {
  color: #4e6e8a;
  text-decoration: none;
  text-transform: uppercase;
  padding-bottom: 3px;
  margin-bottom: 3px;
}

a:hover {
  background-color: #4e6e8a;
  text-decoration: underline;
  color: white;
}

a:active {
  background-color: #4e6e8a;
}

tr, th, td {
  border: 2px solid #4e6e8a;
  padding: 5px;
}

.tabs {
  display: flex;
  cursor: pointer;
}

.tab {
  padding: 10px 20px;
  border: 1px solid #ccc;
  border-bottom: none;
  background: #f1f1f1;
}

.tab:hover {
  background: #4e6e8a;
  color: white; /* ensure contrast on hover */
}

.tab.active {
  background: #4e6e8a;
  color: white;
  font-weight: bold;
}

.tab-content {
  border: 1px solid #ccc;
  padding: 20px;
  background: #fff;
}

.tab-content > div {
  display: none;
}

.tab-content > div.active {
  display: block;
}
</style>


  <script>
  document.querySelectorAll('.tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      const activeTab = document.querySelector('.tab.active');
      const activePanel = document.querySelector('.tab-panel.active');

      if (activeTab) {
        activeTab.classList.remove('active');
      }

      if (activePanel) {
        activePanel.classList.remove('active');
      }

      tab.classList.add('active');
      const tabIndex = tab.getAttribute('data-tab');
      const targetPanel = document.getElementById(`tab-${tabIndex}`);

      if (targetPanel) {
        targetPanel.classList.add('active');
      }
    });
  });
</script>
